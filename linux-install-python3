#!/bin/bash

set -e

echo "==> Detecting package manager..."

install_python() {
    if command -v python3 &>/dev/null; then
        echo "Python3 already installed: $(python3 --version)"
        exit 0
    fi

    # apt (Debian/Ubuntu/Mint/Kali)
    if command -v apt-get &>/dev/null; then
        echo "==> Using apt"
        sudo apt-get update -y
        sudo apt-get install -y python3 python3-pip
        return
    fi

    # pacman (Arch/Manjaro/EndeavourOS)
    if command -v pacman &>/dev/null; then
        echo "==> Using pacman"
        sudo pacman -Sy --noconfirm python python-pip
        return
    fi

    # dnf (Fedora/RHEL 8+/CentOS Stream)
    if command -v dnf &>/dev/null; then
        echo "==> Using dnf"
        sudo dnf install -y python3 python3-pip
        return
    fi

    # yum (CentOS 7/RHEL 7)
    if command -v yum &>/dev/null; then
        echo "==> Using yum"
        sudo yum install -y python3 python3-pip
        return
    fi

    # zypper (openSUSE/SLES)
    if command -v zypper &>/dev/null; then
        echo "==> Using zypper"
        sudo zypper install -y python3 python3-pip
        return
    fi

    # apk (Alpine Linux)
    if command -v apk &>/dev/null; then
        echo "==> Using apk"
        sudo apk add --no-cache python3 py3-pip
        return
    fi

    # xbps (Void Linux)
    if command -v xbps-install &>/dev/null; then
        echo "==> Using xbps"
        sudo xbps-install -Sy python3 python3-pip
        return
    fi

    # emerge (Gentoo)
    if command -v emerge &>/dev/null; then
        echo "==> Using emerge"
        sudo emerge dev-lang/python
        return
    fi

    # nix (NixOS / nix-env)
    if command -v nix-env &>/dev/null; then
        echo "==> Using nix-env"
        nix-env -iA nixpkgs.python3
        return
    fi

    # snap (fallback)
    if command -v snap &>/dev/null; then
        echo "==> Using snap"
        sudo snap install python3
        return
    fi

    # brew (Homebrew on Linux)
    if command -v brew &>/dev/null; then
        echo "==> Using brew"
        brew install python3
        return
    fi

    # Last resort: build from source
    echo "==> No package manager found. Building from source..."
    sudo apt-get install -y build-essential zlib1g-dev libncurses5-dev \
        libgdbm-dev libnss3-dev libssl-dev libreadline-dev libffi-dev \
        libsqlite3-dev wget 2>/dev/null || true

    PYTHON_VERSION="3.12.3"
    wget https://www.python.org/ftp/python/${PYTHON_VERSION}/Python-${PYTHON_VERSION}.tgz
    tar -xf Python-${PYTHON_VERSION}.tgz
    cd Python-${PYTHON_VERSION}
    ./configure --enable-optimizations
    make -j$(nproc)
    sudo make altinstall
    cd ..
    rm -rf Python-${PYTHON_VERSION} Python-${PYTHON_VERSION}.tgz
    return
}

install_python

echo ""
echo "==> Done! Python version: $(python3 --version 2>/dev/null || python3.12 --version)"
